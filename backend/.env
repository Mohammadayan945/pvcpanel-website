# ============================================
# PVC CONTRACTOR WEBSITE - BACKEND ENV CONFIG
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pvc_contractor
